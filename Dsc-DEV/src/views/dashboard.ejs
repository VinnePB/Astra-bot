<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Astra | Admin Dashboard</title>
</head>
<body>
    <nav>
        <h2>Astra Dashboard</h2>
        <a href="/logout">Logout</a>
    </nav>

    <main>
        <section class="settings-panel">
            <h2>Verification Settings</h2>
            <form action="/api/update-verification" method="POST">
                
                <input type="hidden" name="guild_id" value="<%= settings.guild_id %>">

                <label>
                    <input type="checkbox" name="two_step" <%= settings.two_step_enabled ? 'checked' : '' %>>
                    Enable 2-Step Verification
                </label>
                <br>
                <label>Member Role ID:
                    <input type="text" name="member_role_id" value="<%= settings.member_role_id || '' %>">
                </label>
                <button type="submit">Save Changes</button>
            </form>
        </section>

        <section class="stats">
            <h2>Server Overview</h2>
            <p>Status: <strong>Active</strong></p>
            <p>Total Verifications: 1,240</p>
        </section>
    </main>
</body>
</html>