<% layout('layout') %>

<main class="max-w-4xl mx-auto p-6 mt-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <div class="md:col-span-2 bg-slate-900 p-6 rounded-2xl border border-slate-800 shadow-xl">
            <h2 class="text-lg font-semibold mb-4 border-b border-slate-800 pb-2">Verification Settings</h2>
            
            <form action="/api/update-verification" method="POST" class="space-y-6">
                <input type="hidden" name="guild_id" value="<%= settings.guild_id %>">
                
                <div class="flex items-center justify-between p-4 bg-slate-800/50 rounded-lg border border-slate-700">
                    <label class="text-slate-300">Enable 2-Step Verification</label>
                    <input type="checkbox" name="two_step" <%= settings.two_step_enabled ? 'checked' : '' %> 
                        class="w-5 h-5 accent-indigo-500 rounded cursor-pointer">
                </div>

                <div>
                    <label class="block text-sm text-slate-400 mb-2">Member Role</label>
                    <select name="member_role_id" 
                        class="w-full bg-slate-800 border border-slate-700 rounded-lg p-3 outline-none focus:border-indigo-500 transition-all text-white">
                        <option value="" disabled <%= !settings.member_role_id ? 'selected' : '' %>>Selecione um cargo...</option>
                        <% roles.forEach(role => { %>
                            <% if (role.id !== settings.guild_id) { %>
                                <option value="<%= role.id %>" <%= settings.member_role_id === role.id ? 'selected' : '' %>>
                                    @<%= role.name %>
                                </option>
                            <% } %>
                        <% }) %>
                    </select>
                </div>

                <div>
                    <label class="block text-sm text-slate-400 mb-2">Log Channel</label>
                    <select name="log_channel_id" 
                        class="w-full bg-slate-800 border border-slate-700 rounded-lg p-3 outline-none focus:border-indigo-500 transition-all text-white">
                        <option value="" <%= !settings.log_channel_id ? 'selected' : '' %>>Nenhum canal selecionado</option>
                        <% channels.forEach(channel => { %>
                            <option value="<%= channel.id %>" <%= settings.log_channel_id === channel.id ? 'selected' : '' %>>
                                #<%= channel.name %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <button type="submit" 
                    class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 rounded-lg transition-all shadow-lg shadow-indigo-900/20">
                    Save Changes
                </button>
            </form>
        </div>

        <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800 shadow-xl self-start">
            <h3 class="text-sm font-medium text-slate-400 mb-2">Server Status</h3>
            <div class="flex items-center gap-2 mb-6">
                <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></div>
                <span class="text-green-500 font-bold">Active</span>
            </div>
            
            <h3 class="text-sm font-medium text-slate-400 mb-2">Total Verifications</h3>
            <p class="text-3xl font-bold text-white">1,240</p>
        </div>

    </div>
</main>

<script>
    // Toast Notification para feedback de sucesso
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has('status') && urlParams.get('status') === 'success') {
        const toast = document.createElement('div');
        toast.className = 'fixed top-5 right-5 bg-green-600 text-white px-6 py-3 rounded-lg shadow-xl animate-bounce z-50';
        toast.textContent = 'Configurações salvas com sucesso!';
        document.body.appendChild(toast);
        
        setTimeout(() => toast.remove(), 3000);
        window.history.replaceState({}, document.title, window.location.pathname);
    }
</script>